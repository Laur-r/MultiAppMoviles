<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F5"
    tools:context=".AgendaBuscarActivity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/edtBuscar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Buscar por cédula"
                android:inputType="text"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="8dp" />

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:onClick="buscar"
                android:text="Buscar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#C97BAE"
                android:layout_marginBottom="12dp"
                style="@style/Widget.MaterialComponents.Button"
                app:cornerRadius="16dp" />

            <TextView
                android:id="@+id/textView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Información de Contacto"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#4A2040"
                android:paddingTop="4dp"
                android:paddingBottom="12dp" />

            <EditText android:id="@+id/edtName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre"
                android:inputType="text"
                android:focusable="false"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp" />

            <EditText android:id="@+id/edtLastname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Apellido"
                android:inputType="text"
                android:focusable="false"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp" />

            <EditText android:id="@+id/edtId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Cédula"
                android:inputType="text"
                android:focusable="false"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp" />

            <EditText android:id="@+id/edtPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Teléfono"
                android:inputType="text"
                android:focusable="false"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp" />

            <EditText android:id="@+id/edtEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Correo"
                android:inputType="text"
                android:focusable="false"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp" />

            <EditText android:id="@+id/edtAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Dirección"
                android:inputType="text"
                android:focusable="false"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp" />

            <EditText android:id="@+id/edtBirthday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Fecha de Nacimiento"
                android:inputType="text"
                android:focusable="false"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp" />

            <EditText android:id="@+id/edtGender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Sexo"
                android:inputType="text"
                android:focusable="false"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp" />

            <EditText android:id="@+id/edtInterests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Intereses"
                android:inputType="text"
                android:focusable="false"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="12dp" />
            <!-- Después de edtInterests -->
            <EditText android:id="@+id/edtPreferences"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Preferencias"
                android:focusable="false"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnGuardarCambios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guardar Cambios"
                android:onClick="guardarCambios"
                android:textColor="#FFFFFF"
                android:backgroundTint="#B5589A"
                android:visibility="gone"
                android:layout_marginBottom="6dp"
                style="@style/Widget.MaterialComponents.Button"
                app:cornerRadius="16dp"/>

            <Button
                android:id="@+id/btnEditar"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#B5589A"
                android:onClick="editar"
                android:text="Editar"
                android:textColor="#FFFFFF"
                app:cornerRadius="16dp" />

            <Button
                android:id="@+id/btnVolver"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Regresar"
                android:onClick="regresar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#B5589A"
                android:layout_marginBottom="12dp"
                style="@style/Widget.MaterialComponents.Button"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>