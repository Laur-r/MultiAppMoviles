<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F5"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/edtBuscar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Buscar por cédula"
                android:inputType="text"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="8dp"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:onClick="buscar"
                android:text="Buscar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#C97BAE"
                android:layout_marginBottom="12dp"
                app:cornerRadius="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Información de Contacto"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#4A2040"
                android:paddingTop="4dp"
                android:paddingBottom="12dp"/>

            <EditText
                android:id="@+id/edtName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre"
                android:inputType="text"
                android:focusable="false"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/edtLastname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Apellido"
                android:inputType="text"
                android:focusable="false"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/edtId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Cédula"
                android:inputType="text"
                android:focusable="false"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/edtPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Teléfono"
                android:inputType="phone"
                android:focusable="false"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/edtEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Correo"
                android:inputType="textEmailAddress"
                android:focusable="false"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/edtAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Dirección"
                android:inputType="text"
                android:focusable="false"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp"/>


            <EditText
                android:id="@+id/edtBirthday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Fecha de Nacimiento"
                android:focusable="false"
                android:clickable="true"
                android:cursorVisible="false"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:drawableEnd="@android:drawable/ic_menu_my_calendar"
                android:drawableTint="#C97BAE"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/edtGender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Sexo"
                android:inputType="text"
                android:focusable="false"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Intereses"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#4A2040"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvInterests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#4A2040"
                android:textSize="14sp"
                android:background="@android:color/transparent"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Preferencias de ocio"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#4A2040"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvPreferences"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#4A2040"
                android:textSize="14sp"
                android:background="@android:color/transparent"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnEditarIntereses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Editar intereses y preferencias"
                android:onClick="editarIntereses"
                android:textColor="#FFFFFF"
                android:backgroundTint="#C97BAE"
                android:visibility="gone"
                android:layout_marginBottom="6dp"
                app:cornerRadius="16dp"/>

            <Button
                android:id="@+id/btnGuardarCambios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guardar Cambios"
                android:onClick="guardarCambios"
                android:textColor="#FFFFFF"
                android:backgroundTint="#B5589A"
                android:visibility="gone"
                android:layout_marginBottom="6dp"
                app:cornerRadius="16dp"/>

            <Button
                android:id="@+id/btnEditar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Editar datos personales"
                android:onClick="editar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#B5589A"
                android:visibility="gone"
                android:layout_marginBottom="6dp"
                app:cornerRadius="16dp"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Regresar"
                android:onClick="regresar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4A2040"
                android:layout_marginBottom="12dp"
                app:cornerRadius="16dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>