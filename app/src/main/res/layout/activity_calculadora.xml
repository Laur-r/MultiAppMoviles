<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF0F5"
    android:padding="20dp">

    <EditText
        android:id="@+id/caja"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FDDCEE"
        android:cursorVisible="false"
        android:focusable="false"
        android:gravity="center_vertical|end"
        android:paddingEnd="16dp"
        android:text="0"
        android:textColor="#4A2040"
        android:textSize="28sp"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button android:id="@+id/b7"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#F9E4EF" android:onClick="t7" android:text="7"
            android:textColor="#4A2040" android:textSize="18sp"
            app:cornerRadius="16dp" app:strokeColor="#E8B4D0" app:strokeWidth="1dp"/>

        <Button android:id="@+id/b8"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#F9E4EF" android:onClick="t8" android:text="8"
            android:textColor="#4A2040" android:textSize="18sp"
            app:cornerRadius="16dp" app:strokeColor="#E8B4D0" app:strokeWidth="1dp"/>

        <Button android:id="@+id/b9"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#F9E4EF" android:onClick="t9" android:text="9"
            android:textColor="#4A2040" android:textSize="18sp"
            app:cornerRadius="16dp" app:strokeColor="#E8B4D0" app:strokeWidth="1dp"/>

        <Button android:id="@+id/division"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1"
            android:backgroundTint="#C97BAE" android:onClick="division" android:text="÷"
            android:textColor="#FFFFFF" android:textSize="22sp"
            app:cornerRadius="16dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button android:id="@+id/b4"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#F9E4EF" android:onClick="t4" android:text="4"
            android:textColor="#4A2040" android:textSize="18sp"
            app:cornerRadius="16dp" app:strokeColor="#E8B4D0" app:strokeWidth="1dp"/>

        <Button android:id="@+id/b5"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#F9E4EF" android:onClick="t5" android:text="5"
            android:textColor="#4A2040" android:textSize="18sp"
            app:cornerRadius="16dp" app:strokeColor="#E8B4D0" app:strokeWidth="1dp"/>

        <Button android:id="@+id/b6"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#F9E4EF" android:onClick="t6" android:text="6"
            android:textColor="#4A2040" android:textSize="18sp"
            app:cornerRadius="16dp" app:strokeColor="#E8B4D0" app:strokeWidth="1dp"/>

        <Button android:id="@+id/multiplicacion"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1"
            android:backgroundTint="#C97BAE" android:onClick="multiplicacion" android:text="×"
            android:textColor="#FFFFFF" android:textSize="22sp"
            app:cornerRadius="16dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button android:id="@+id/b1"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#F9E4EF" android:onClick="t1" android:text="1"
            android:textColor="#4A2040" android:textSize="18sp"
            app:cornerRadius="16dp" app:strokeColor="#E8B4D0" app:strokeWidth="1dp"/>

        <Button android:id="@+id/b2"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#F9E4EF" android:onClick="t2" android:text="2"
            android:textColor="#4A2040" android:textSize="18sp"
            app:cornerRadius="16dp" app:strokeColor="#E8B4D0" app:strokeWidth="1dp"/>

        <Button android:id="@+id/b3"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#F9E4EF" android:onClick="t3" android:text="3"
            android:textColor="#4A2040" android:textSize="18sp"
            app:cornerRadius="16dp" app:strokeColor="#E8B4D0" app:strokeWidth="1dp"/>

        <Button android:id="@+id/resta"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1"
            android:backgroundTint="#C97BAE" android:onClick="resta" android:text="−"
            android:textColor="#FFFFFF" android:textSize="22sp"
            app:cornerRadius="16dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button android:id="@+id/clean"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#E8A0C8" android:onClick="limpiar" android:text="C"
            android:textColor="#FFFFFF" android:textSize="18sp"
            app:cornerRadius="16dp"/>

        <Button android:id="@+id/bp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#F9E4EF" android:onClick="punto" android:text="."
            android:textColor="#4A2040" android:textSize="22sp"
            app:cornerRadius="16dp" app:strokeColor="#E8B4D0" app:strokeWidth="1dp"/>

        <Button android:id="@+id/b0"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#F9E4EF" android:onClick="t0" android:text="0"
            android:textColor="#4A2040" android:textSize="18sp"
            app:cornerRadius="16dp" app:strokeColor="#E8B4D0" app:strokeWidth="1dp"/>

        <Button android:id="@+id/suma"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1"
            android:backgroundTint="#C97BAE" android:onClick="suma" android:text="+"
            android:textColor="#FFFFFF" android:textSize="22sp"
            app:cornerRadius="16dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button android:id="@+id/igual2"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp" android:layout_height="66dp" android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#B5589A" android:onClick="memoria" android:text="Historial"
            android:textColor="#FFFFFF" android:textSize="16sp"
            app:cornerRadius="20dp"/>

        <Button android:id="@+id/igual"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp" android:layout_height="66dp" android:layout_weight="2"
            android:backgroundTint="#B5589A" android:onClick="igual" android:text="="
            android:textColor="#FFFFFF" android:textSize="22sp"
            app:cornerRadius="20dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/button"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#4A2040"
        android:onClick="regresar"
        android:text="Regresar al Menú"
        android:textColor="#FFFFFF"
        app:cornerRadius="16dp"/>

</LinearLayout>