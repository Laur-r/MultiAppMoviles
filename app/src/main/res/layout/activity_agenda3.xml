<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F5">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Preferencias"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#4A2040"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"/>

            <CheckBox
                android:id="@+id/cbPlaya"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Playa"
                android:textColor="#4A2040"
                android:buttonTint="#C97BAE"/>

            <CheckBox
                android:id="@+id/cbMontana"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Montaña"
                android:textColor="#4A2040"
                android:buttonTint="#C97BAE"/>

            <CheckBox
                android:id="@+id/cbCiudad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ciudad"
                android:textColor="#4A2040"
                android:buttonTint="#C97BAE"/>

            <CheckBox
                android:id="@+id/cbCampo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Campo"
                android:textColor="#4A2040"
                android:buttonTint="#C97BAE"/>

            <CheckBox
                android:id="@+id/cbNoche"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Noche"
                android:textColor="#4A2040"
                android:buttonTint="#C97BAE"/>

            <CheckBox
                android:id="@+id/cbDia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Día"
                android:textColor="#4A2040"
                android:buttonTint="#C97BAE"/>

            <CheckBox
                android:id="@+id/cbSolo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Solo"
                android:textColor="#4A2040"
                android:buttonTint="#C97BAE"/>

            <CheckBox
                android:id="@+id/cbGrupo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Grupo"
                android:textColor="#4A2040"
                android:buttonTint="#C97BAE"/>

            <CheckBox
                android:id="@+id/cbInterior"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Interior"
                android:textColor="#4A2040"
                android:buttonTint="#C97BAE"/>

            <CheckBox
                android:id="@+id/cbExterior"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Exterior"
                android:textColor="#4A2040"
                android:buttonTint="#C97BAE"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp"
                android:backgroundTint="#B5589A"
                android:onClick="guardar"
                android:text="Guardar Usuario"
                android:textColor="#FFFFFF"
                app:cornerRadius="16dp" />

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Regresar"
                android:onClick="regresar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4A2040"
                android:layout_marginBottom="12dp"
                app:cornerRadius="16dp"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>