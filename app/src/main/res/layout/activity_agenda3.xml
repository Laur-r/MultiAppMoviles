<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F5"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Preferencias"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="#4A2040"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¿Qué actividades disfrutas en tu tiempo libre?"
                android:textAlignment="center"
                android:textSize="13sp"
                android:textColor="#C97BAE"
                android:paddingBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <CheckBox
                    android:id="@+id/cbCinePref"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ir al cine"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>

                <CheckBox
                    android:id="@+id/cbConciertos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Conciertos"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <CheckBox
                    android:id="@+id/cbRestaurantes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Restaurantes"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>

                <CheckBox
                    android:id="@+id/cbTeatro"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Teatro"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <CheckBox
                    android:id="@+id/cbNaturaleza"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Naturaleza"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>

                <CheckBox
                    android:id="@+id/cbVideojuegos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Videojuegos"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <CheckBox
                    android:id="@+id/cbCompras"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Compras"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>

                <CheckBox
                    android:id="@+id/cbFestivales"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Festivales"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <CheckBox
                    android:id="@+id/cbMuseos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Museos"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>

                <CheckBox
                    android:id="@+id/cbDeportesPref"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Gym / Sport"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>
            </LinearLayout>

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="6dp"
                android:backgroundTint="#B5589A"
                android:onClick="guardar"
                android:text="Guardar Usuario"
                android:textColor="#FFFFFF"
                app:cornerRadius="16dp" />

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Regresar"
                android:onClick="regresar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4A2040"
                android:layout_marginBottom="12dp"
                app:cornerRadius="16dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>