<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F5"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Intereses"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="#4A2040"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selecciona todos los que apliquen"
                android:textAlignment="center"
                android:textSize="13sp"
                android:textColor="#C97BAE"
                android:paddingBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <CheckBox
                    android:id="@+id/cbDeporte"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Deporte"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>

                <CheckBox
                    android:id="@+id/cbMusica"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Música"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <CheckBox
                    android:id="@+id/cbCine"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cine"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>

                <CheckBox
                    android:id="@+id/cbArte"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Arte"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <CheckBox
                    android:id="@+id/cbLectura"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lectura"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>

                <CheckBox
                    android:id="@+id/cbViajes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Viajes"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <CheckBox
                    android:id="@+id/cbCocina"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cocina"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>

                <CheckBox
                    android:id="@+id/cbTecnologia"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tecnología"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <CheckBox
                    android:id="@+id/cbModa"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Moda"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>

                <CheckBox
                    android:id="@+id/cbFotografia"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fotografía"
                    android:textColor="#4A2040"
                    android:textSize="14sp"
                    android:buttonTint="#C97BAE"/>
            </LinearLayout>

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Siguiente: Preferencias"
                android:onClick="preferencias"
                android:textColor="#FFFFFF"
                android:backgroundTint="#C97BAE"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="6dp"
                app:cornerRadius="16dp"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Regresar"
                android:onClick="regresar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4A2040"
                android:layout_marginBottom="12dp"
                app:cornerRadius="16dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>