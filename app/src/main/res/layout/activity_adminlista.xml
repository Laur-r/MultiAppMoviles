<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFF0F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp"
        android:text="Lista de Usuarios"
        android:textAlignment="center"
        android:textColor="#4A2040"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mantén presionado para eliminar"
        android:textAlignment="center"
        android:textSize="12sp"
        android:textColor="#C497B2"
        android:paddingBottom="16dp"/>

    <TextView
        android:id="@+id/tvVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No hay usuarios creados aún"
        android:textAlignment="center"
        android:textColor="#C497B2"
        android:textSize="16sp"
        android:paddingTop="32dp"
        android:visibility="gone"/>

    <ListView
        android:id="@+id/listView"
        android:layout_width="wrap_content"
        android:layout_height="502dp"
        android:layout_weight="1"
        android:divider="#E8B4D0"
        android:dividerHeight="1dp" />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Regresar"
        android:onClick="regresar"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4A2040"
        android:layout_marginTop="12dp"
        style="@style/Widget.MaterialComponents.Button"
        app:cornerRadius="16dp"/>

</LinearLayout>