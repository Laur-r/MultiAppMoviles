<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F5"
    tools:context=".AgendaActivity1">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="1dp"
        android:layout_marginTop="1dp"
        android:layout_marginEnd="1dp"
        android:layout_marginBottom="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            >

            <Button
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#4A2040"
                android:onClick="regresar"
                android:text="Volver"
                android:textColor="#FFFFFF"
                app:cornerRadius="16dp" />

            <TextView
                android:id="@+id/textView3"
                android:layout_width="373dp"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="Información Personal"
                android:textAlignment="center"
                android:textColor="#4A2040"
                android:textSize="20sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ems="10"
                android:inputType="text"
                android:hint ="Nombre"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/edtApellido"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ems="10"
                android:inputType="text"
                android:hint ="Apellido"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/edtCedula"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ems="10"
                android:inputType="text"
                android:hint ="Cedula"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/edtFechaNacimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ems="10"
                android:inputType="text"
                android:hint ="Fecha de Nacimiento"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/edtTelefono"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ems="10"
                android:inputType="text"
                android:hint ="Telefono"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/edtCorreo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ems="10"
                android:inputType="text"
                android:hint ="Correo"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/edtDireccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ems="10"
                android:inputType="text"
                android:hint ="Dirección"
                android:textColor="#4A2040"
                android:textColorHint="#C497B2"
                android:backgroundTint="#E8B4D0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/textView2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sexo:"
                android:textColor="#4A2040"
                android:textStyle="bold"
                android:textSize="15sp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <RadioGroup
                android:id="@+id/rgSexo"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <RadioButton
                    android:id="@+id/rbFemenino"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Femenino"
                    android:textColor="#4A2040"
                    android:buttonTint="#C97BAE" />

                <RadioButton
                    android:id="@+id/rbMasculino"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Masculino"
                    android:textColor="#4A2040"
                    android:buttonTint="#C97BAE" />

            </RadioGroup>


            <Button
                android:id="@+id/btnIntereses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#B5589A"
                android:onClick="intereses"
                android:text="Intereses"
                android:textColor="#FFFFFF"
                app:cornerRadius="16dp" />

            <Button
                android:id="@+id/btnBuscar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#510B5D"
                android:onClick="verAgenda"
                android:text="Ver Contactos" />


        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>